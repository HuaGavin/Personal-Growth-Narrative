# ============================================================
# 个人成长史产品 — .gitignore
# 根目录只保留发布版产品 + README + 本文件
# ============================================================

# --- 系统文件 ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
~$*.xlsx
~$*.docx

# --- 编辑器文件 ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*
*.sublime-workspace

# --- 日志 & 临时文件 ---
*.log
*.tmp
*.temp
*.bak
*.backup

# --- 环境变量 ---
.env
.env.local
.env.*.local

# --- Node.js（如果有） ---
node_modules/
package-lock.json

# --- Python（如果有） ---
__pycache__/
*.py[cod]
*$py.class
dist/
build/
*.egg-info/

# ============================================================
#  内部目录（全部不上传 GitHub）
# ============================================================

# 产品管理文档（需求池、工作流、版本记录等）
product/

# 历史版本 & 开发中版本
versions/

# 个人参考资料 & 私人文件
reference/
